// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/models/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  name     String
  passHash String  @map("pass_hash")

}

model Courier {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  name     String
  passHash String  @map("pass_hash")
}
