generator client {
  provider = "prisma-client"
  output   = "../src/models/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         Int        @id @default(autoincrement())
  email      String     @unique
  number     Int        @unique
  name       String
  passHash   String     @map("pass_hash")
  deliveries Delivery[]
}

model Location {
  id         Int     @id @default(autoincrement())
  number     Int
  street     String
  quarter    String
  city       String
  state      String
  complement String?
}

model Courier {
  id         Int        @id @default(autoincrement())
  email      String     @unique
  name       String
  passHash   String     @map("pass_hash")
  deliveries Delivery[]
}

model Delivery {
  id        Int      @id @default(autoincrement())
  price     Float
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  courier   Courier? @relation(fields: [courierId], references: [id])
  courierId Int?
}
